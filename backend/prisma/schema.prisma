generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile      Profile?
  jobPostings  JobPosting[]
  documents    GeneratedDocument[]
  applications Application[]
  interviews   InterviewSession[]
  evaluations  SelfEvaluation[]
  aiProviderCredentials AiProviderCredential[]
}

model AiProviderCredential {
  id               String   @id @default(cuid())
  userId           String
  provider         String
  authType         String
  encryptedPayload String
  connectedAt      DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  phone           String?
  address         String?
  bio             String?
  profileImageUrl String?
  completeness    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  educations     Education[]
  careers        Career[]
  certifications Certification[]
  projects       Project[]
  skills         Skill[]
  swotAnalysis   SwotAnalysis?
}

model Education {
  id          String    @id @default(cuid())
  profileId   String
  school      String
  major       String
  degree      String
  startDate   DateTime
  endDate     DateTime?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Career {
  id          String    @id @default(cuid())
  profileId   String
  company     String
  position    String
  department  String?
  startDate   DateTime
  endDate     DateTime?
  isCurrent   Boolean   @default(false)
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Certification {
  id           String    @id @default(cuid())
  profileId    String
  name         String
  issuer       String
  issueDate    DateTime
  expiryDate   DateTime?
  credentialId String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Project {
  id           String   @id @default(cuid())
  profileId    String
  name         String
  description  String
  role         String
  techStack    String   @default("[]")
  startDate    DateTime
  endDate      DateTime?
  achievements String?
  url          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Skill {
  id          String      @id @default(cuid())
  profileId   String
  name        String
  category    String?
  proficiency Proficiency @default(INTERMEDIATE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

enum Proficiency {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

model SwotAnalysis {
  id            String   @id @default(cuid())
  profileId     String   @unique
  strengths     String   @default("[]")
  weaknesses    String   @default("[]")
  opportunities String   @default("[]")
  threats       String   @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

enum JobPostingStatus {
  DRAFT
  ANALYZED
  APPLIED
}

model JobPosting {
  id                   String           @id @default(cuid())
  userId               String
  title                String
  company              String?
  url                  String?
  content              String
  status               JobPostingStatus @default(DRAFT)
  analyzedKeywords     String?
  analyzedRequirements String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents   GeneratedDocument[]
  application Application?
}

enum DocumentType {
  RESUME
  PORTFOLIO
}

model GeneratedDocument {
  id           String       @id @default(cuid())
  jobPostingId String
  userId       String
  type         DocumentType
  title        String
  content      String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  jobPosting JobPosting      @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions   DocumentVersion[]
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

model Application {
  id           String            @id @default(cuid())
  userId       String
  jobPostingId String            @unique
  status       ApplicationStatus @default(APPLIED)
  appliedAt    DateTime          @default(now())
  notes        String?
  updatedAt    DateTime          @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobPosting  JobPosting        @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  interviews  InterviewSession[]
  evaluations SelfEvaluation[]
}

enum InterviewType {
  TEXT
  VOICE
}

enum InterviewDifficulty {
  BASIC
  INTERMEDIATE
  ADVANCED
}

enum InterviewStatus {
  IN_PROGRESS
  COMPLETED
}

model InterviewSession {
  id            String              @id @default(cuid())
  applicationId String
  userId        String
  type          InterviewType       @default(TEXT)
  difficulty    InterviewDifficulty @default(INTERMEDIATE)
  status        InterviewStatus     @default(IN_PROGRESS)
  startedAt     DateTime            @default(now())
  endedAt       DateTime?
  feedback      String?

  application Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    InterviewMessage[]
}

enum MessageRole {
  INTERVIEWER
  USER
}

model InterviewMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      MessageRole
  content   String
  createdAt DateTime    @default(now())

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model DocumentVersion {
  id            String   @id @default(cuid())
  documentId    String
  content       String
  versionNumber Int
  createdAt     DateTime @default(now())

  document GeneratedDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model SelfEvaluation {
  id             String   @id @default(cuid())
  applicationId  String
  userId         String
  performance    Int
  strengths      String?
  improvements   String?
  questionsAsked String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}
