DATABASE_URL=file:./backend/prisma/dev.db
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-another-32-random-characters
PORT=3001
FRONTEND_URL=http://localhost:5173
OPENAI_API_KEY=
# OpenClaw-style Codex OAuth route. Provide either a raw access token,
# a JSON string with { "access"|"access_token": "...", "expires": ... },
# or a path to that JSON file. Override the endpoint only if the Codex
# backend route changes or you proxy it yourself.
OPENAI_CODEX_ACCESS_TOKEN=
OPENAI_CODEX_OAUTH_JSON=
OPENAI_CODEX_OAUTH_FILE=
OPENAI_CODEX_RESPONSES_URL=https://chatgpt.com/backend-api/codex/responses
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
